# HTTP port (default 5000 if omitted)
PORT=5000

# MongoDB connection string (e.g. mongodb://localhost:27017/your-db or Atlas URI)
DB_URL=mongodb://127.0.0.1:27017/jwt-auth

# Access JWT signing secret (use a long random string in production)
JWT_ACCESS_SECRET=change-me-access-secret

# Refresh JWT signing secret (must differ from access secret)
JWT_REFRESH_SECRET=change-me-refresh-secret

# Gmail (or other SMTP): host must be a real hostname, e.g. smtp.gmail.com — not smtp@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-app-password
API_URL=http://localhost:5000/ 
CLIENT_URL=http://localhost:5173/

